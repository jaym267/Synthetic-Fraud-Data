# Virtual environment
venv/
.venv/

# Data (large, license-gated — never commit)
data/

# Trained models (binary artifacts; the metadata/results JSON next to them IS committed)
models/**/*.pkl

# Python
__pycache__/
*.py[cod]
*.egg-info/

# Generated figures ARE committed so the reports render on GitHub
# (regenerate with the src/ scripts; they are small PNGs).

# Kaggle credentials — must never be committed
kaggle.json

# OS / editor cruft
.DS_Store
Thumbs.db
.vscode/
.idea/
